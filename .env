# ============================================
#   YT-DLP Telegram Bot — Configuration
# ============================================

# 🤖 Telegram Bot Token (get from @BotFather)
BOT_TOKEN=Your_Bot_Token

# 👤 Admin User IDs (comma-separated Telegram user IDs)
# These users can use /stats, /cancel_all, /broadcast
ADMIN_IDS=Admins ID

# 📁 Download directory (absolute path recommended)
DOWNLOAD_DIR=./downloads

# 🍪 Cookies file path
COOKIES_FILE=./cookies.txt

# ⚙️ Max concurrent downloads per user
MAX_CONCURRENT_PER_USER=2

# ⚙️ Max concurrent downloads total
MAX_CONCURRENT_TOTAL=5

# 📦 Max file size to send via Telegram (MB) — Telegram limit is 50MB for bots
MAX_FILE_SIZE_MB=50

# 🧹 Auto-delete downloaded files after sending (true/false)
AUTO_DELETE_FILES=true

# 🔒 Restrict to specific users only? Set to false for public use
RESTRICTED_MODE=false

# 📋 Allowed user IDs when restricted (comma-separated)
ALLOWED_USERS=

# 🌐 Proxy (optional, e.g. socks5://user:pass@host:port)
PROXY=
